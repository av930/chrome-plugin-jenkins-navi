{
  "comment":"이 파일은 plugin 최초 설치시 option에 default로 들어가는 설정입니다.",
  "sites": {
    "V1": "http://jenkins.rge.com/jenkins01",
    "V2": "http://jenkins.rge.com/jenkins02",
    "V3": "http://jenkins.rge.com/jenkins03",
    "V6": "http://jenkins.rge.com/jenkins06",
    "RM": "http://ci.vbee.rge.com/vsrms/"
  },
  "menus": {
    "node": ["computer","function/label"],
    "trigger": "gerrit_manual_trigger",
    "assign/role": ["role-strategy/manage-roles","role-strategy/assign-roles"],
    "credentials": "credentials",
    "env-config": "configure",
    "toolconfig": "configureTools",
    "systemInfo": "systemInfo"
  },
  "job": {
    "text/log": ["lastBuild/timestamps/?time=HH:mm:ss&timeZone=GMT+9&appendLog","lastBuild/consoleText"],
    "cons/log": ["lastBuild/console","lastBuild/consoleFull"],
    "env/param": ["lastBuild/injectedEnvVars","lastBuild/parameters"],
    "configure": "configure"
  },
  "custom": {
   "honda26my": ["http://jenkins.rge.com/jenkins06/view/", "http://jenkins.rge.com/jenkins06/job/honda_buildchecker/"],
   "connect_w": ["http://jenkins.rge.com/jenkins03/view/", "http://jenkins.rge.com/jenkins03/job/ccc_Atriggerbuild/"],
    "vgit_na": "https://vgit.rge.com/na",
    "vgit_eu": "https://vgit.rge.com/eu",
    "vgit_as": "https://vgit.rge.com/as",
    "collab": "https://collab.rge.com",
    "jira": "https://jira.rge.com",
    "custom": "http://your.custom.com"
  },
  "run": {
    "rm-history": "http://jenkins.rge.com/jenkins03/job/_SFolder_CommonUtility/job/ControlJenkins/buildWithParameters?token=plugin",
    "retrigger": "http://jenkins.rge.com/jenkins03/job/Common_retriggerJOB/buildWithParameters?token=plugin",
    "temp_job": "http://jenkins.rge.com/jenkins03/job/ControlJenkins/buildWithParameters?token=plugin"
  }
}
